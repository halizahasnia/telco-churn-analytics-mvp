LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Used only if LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Used only if LLM_PROVIDER=gemini
# GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash

